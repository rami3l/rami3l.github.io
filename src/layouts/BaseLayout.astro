---
import BaseHead from "../components/BaseHead.astro";
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <BaseHead title={title} description={description} />

    <script is:inline>
      let dark = false;
      if (localStorage.getItem("darkMode")) {
        dark = JSON.parse(localStorage.getItem("darkMode") ?? "false");
      } else {
        dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      }

      var root = document.getElementsByTagName("html")[0];
      if (dark) {
        root.classList.add("dark");
      } else {
        root.classList.remove("dark");
      }
    </script>

    <style is:global>
      html.dark .astro-code,
      html.dark .astro-code span {
        color: var(--shiki-dark);
      }

      html:not(dark) .astro-code,
      html:not(dark) .astro-code span {
        color: var(--shiki-light);
      }

      pre.astro-code {
        @apply overflow-x-auto rounded-xl !important;
        @apply border border-base-300 dark:border-base-700 bg-base-200/50 dark:bg-base-950/30 !important;
      }

      .code-block {
        @apply my-8 rounded-xl border border-base-300 dark:border-base-700 overflow-hidden;
        @apply bg-base-200/50 dark:bg-base-950/30;
      }

      .code-block > pre.astro-code {
        @apply m-0 rounded-none border-0 !important;
        background: transparent !important;
      }

      .code-block-toolbar {
        @apply flex items-center justify-between gap-3 px-4 py-2 border-b border-base-300 dark:border-base-700;
        @apply bg-base-100/80 dark:bg-base-900/70;
      }

      .code-block-meta {
        @apply flex items-center gap-2 text-xs text-base-600 dark:text-base-400;
      }

      .code-language {
        @apply uppercase tracking-wider font-semibold px-2 py-0.5 rounded-full;
        @apply bg-base-200 dark:bg-base-800 text-base-700 dark:text-base-200;
      }

      .code-block-actions {
        @apply flex items-center gap-2;
      }

      .code-action {
        @apply text-xs px-2.5 py-1 rounded-md border border-base-300 dark:border-base-700;
        @apply bg-base-100 dark:bg-base-900 text-base-700 dark:text-base-200;
        @apply hover:bg-base-200 dark:hover:bg-base-800 transition-colors;
      }

      .code-action-copied {
        @apply bg-green-200 dark:bg-green-900 border-green-300 dark:border-green-700 text-green-800 dark:text-green-300;
      }

      pre.astro-code.no-wrap {
        white-space: pre !important;
        word-wrap: normal !important;
      }

      .line.highlighted {
        @apply bg-accent-500/10 dark:bg-accent-700/10;
      }

      ::selection {
        @apply bg-accent-300/50 dark:bg-accent-900/40;
      }

      lite-youtube {
        @apply rounded-xl border border-base-300 dark:border-base-700;
      }

      .prose mark {
        @apply bg-accent-200 dark:bg-accent-900 text-black dark:text-white;
      }
      .MathJax svg {
        display: inline !important;
      }
    </style>
  </head>

  <body
    class="bg-base-100 dark:bg-base-950 flex mx-1 sm:mx-4 transition-all duration-150"
  >
    <div class="max-w-4xl mx-auto my-1 sm:my-8 w-full">
      <div class="w-full">
        <slot />
      </div>
    </div>

    <!-- <div class="fixed inset-0 h-full w-full -z-50">
      <div
        class="h-full w-full max-w-5xl mx-auto bg-base-50 ring-1 ring-base-200 dark:bg-base-900 dark:ring-base-300/20 shadow-lg"
      >
      </div>
    </div> -->
  </body>
</html>
